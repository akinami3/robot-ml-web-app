# =============================================================================
# Step 7: FastAPI バックエンド — 開発用 Dockerfile
# =============================================================================
#
# 【Step 6 からの変更点】
# - psycopg2-binary のビルドに必要な libpq-dev を追加
# - Alembic のマイグレーション機能を使えるようにする
#
# 【なぜ libpq-dev が必要？】
# psycopg2-binary は PostgreSQL の C ライブラリ (libpq) に依存する。
# slim イメージにはこのライブラリが含まれていないため、
# apt-get で追加インストールする必要がある。
#
# asyncpg は pure Python + Cython なので追加パッケージ不要。
#
# =============================================================================

FROM python:3.12-slim

# --- システム依存パッケージのインストール ---
# libpq-dev: psycopg2 (PostgreSQL ドライバー) に必要
# gcc: C 拡張のコンパイルに必要な場合がある
RUN apt-get update && \
    apt-get install -y --no-install-recommends libpq-dev gcc && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- 依存関係のインストール ---
COPY pyproject.toml .
RUN pip install --no-cache-dir -e "."

# --- ソースコードのコピー ---
COPY . .

EXPOSE 8000

# --- 起動コマンド ---
# docker-compose.yml の command で上書きされるが、
# 単独ビルド時のデフォルトコマンドとして設定。
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
