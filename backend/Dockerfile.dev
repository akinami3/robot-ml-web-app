# =============================================================================
# Step 6: FastAPI バックエンド — 開発用 Dockerfile
# =============================================================================
#
# 【Dockerfile とは？】
# コンテナイメージのビルド手順を記述するファイル。
# レシピのようなもので、どのベースイメージを使い、
# どのファイルをコピーし、どのコマンドを実行するかを定義する。
#
# 【開発用（dev）と本番用の違い】
# 開発用: ソースコードをボリュームマウント → ホットリロード
# 本番用: ソースコードをイメージに COPY → 固定
# Step 6 では開発用の Dockerfile.dev のみ作成する。
#
# =============================================================================

# --- ベースイメージ ---
# python:3.12-slim は Debian ベースの軽量イメージ。
# Alpine 版（python:3.12-alpine）はさらに小さいが、
# C 拡張ライブラリのビルドが面倒になるため slim を推奨。
FROM python:3.12-slim

# --- 作業ディレクトリ ---
# コンテナ内のカレントディレクトリを設定。
# 以降のコマンドはすべてこのディレクトリで実行される。
WORKDIR /app

# --- 依存関係のインストール ---
# pyproject.toml を先にコピーすることで、
# ソースコード変更時に依存インストールのキャッシュが効く。
# Docker はレイヤーキャッシュを使うため、
# 変更がないレイヤーは再実行されない。
COPY pyproject.toml .

# pip install でプロジェクトの依存関係をインストール。
# --no-cache-dir: pip キャッシュを作らない（イメージサイズ削減）
RUN pip install --no-cache-dir -e "."

# --- ソースコードのコピー ---
# 開発時は docker-compose.yml で volume マウントするため、
# ここでのコピーは初回ビルド用。
COPY . .

# --- ポート公開の宣言 ---
# EXPOSE はドキュメンテーション目的。
# 実際のポートマッピングは docker-compose.yml の ports で行う。
EXPOSE 8000

# --- 起動コマンド ---
# uvicorn: ASGI サーバー（FastAPI を動かすアプリケーションサーバー）
# --host 0.0.0.0: すべてのインターフェースでリッスン（コンテナ外からアクセス可能に）
# --port 8000: ポート番号
# --reload: ファイル変更を検知して自動リスタート（開発用）
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
